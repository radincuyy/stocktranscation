// Prisma schema — Stock Transaction module
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionStatus {
  ACTIVE
  CANCELLED
}

/// Unit used on a stock transaction form (grosir vs eceran)
enum StockUnitType {
  PURCHASE
  SALE
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  sku            String   @unique
  purchaseUnit   String
  saleUnit       String
  /// 1 purchase unit = conversionRate sale units (e.g. 1 Drum = 200 Liter)
  conversionRate Decimal  @db.Decimal(18, 6)
  /// Stock always stored in sale (base) unit, supports decimals
  stockQty       Decimal  @default(0) @db.Decimal(18, 6)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions StockTransaction[]

  @@map("products")
}

model StockTransaction {
  id         String            @id @default(uuid()) @db.Uuid
  sequenceNo String            @unique
  date       DateTime          @db.Date
  productId  String            @db.Uuid
  quantity   Decimal           @db.Decimal(18, 6)
  unitType   StockUnitType
  note       String?
  status     TransactionStatus @default(ACTIVE)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([date])
  @@index([status])
  @@map("stock_transactions")
}

/// Row-lock friendly counter for concurrent sequence generation
/// key example: "Senin-VII-2026"
model SequenceCounter {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("sequence_counters")
}
