// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionStatus {
  ACTIVE
  CANCELLED
}

/// Satuan yang dipakai di form transaksi stok (grosir vs eceran)
enum StockUnitType {
  PURCHASE
  SALE
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  sku            String   @unique
  purchaseUnit   String
  saleUnit       String
  /// 1 satuan beli = conversionRate satuan jual (contoh: 1 Drum = 200 Liter)
  conversionRate Decimal  @db.Decimal(18, 6)
  /// Stok selalu disimpan dalam satuan jual (base), mendukung desimal
  stockQty       Decimal  @default(0) @db.Decimal(18, 6)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions StockTransaction[]

  @@map("products")
}

model StockTransaction {
  id         String            @id @default(uuid()) @db.Uuid
  sequenceNo String            @unique
  date       DateTime          @db.Date
  productId  String            @db.Uuid
  /// Quantity yang diinput user (satuan beli atau jual)
  quantity   Decimal           @db.Decimal(18, 6)
  unitType   StockUnitType
  /// Delta stok absolut dalam satuan base (jual) — dipakai saat cancel
  baseQty    Decimal           @db.Decimal(18, 6)
  note       String?
  status     TransactionStatus @default(ACTIVE)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([date])
  @@index([status])
  @@map("stock_transactions")
}

/// Counter sequence dengan row-lock untuk generate aman saat concurrent
/// contoh key: "Senin-VII-2026"
model SequenceCounter {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("sequence_counters")
}
